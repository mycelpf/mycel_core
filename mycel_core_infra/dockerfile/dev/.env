# mycel_core/infra/dev/.env
# Integration test environment — core shells against fabric providers.
# Secrets → .env.secrets (gitignored).

# ── Build vars ────────────────────────────────────────────────────────────
ROOT_MODULE_NAME=mycel_core
SUBMODULES=

# ── Port configuration (host-side) ───────────────────────────────────────
SERVICE_PORT=9000
WEB_PORT=9002
MCP_PORT=9001

# ── Runtime environment ──────────────────────────────────────────────────
LOG_LEVEL=info
PYTHONOPTIMIZE=2

# ── Service metadata ─────────────────────────────────────────────────────
SERVICE_NAME=mycel_core_service
SERVICE_VERSION=0.1.0
OTEL_SERVICE_NAME=mycel-core-service

# ── Fabric providers (container names on mycel_network) ──────────────────
DATABASE_HOST=mycel_app_db
DATABASE_PORT=5432

KEYCLOAK_URL=http://mycel_keycloak:8080
KEYCLOAK_REALM=mycel

OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://mycel_otel_collector:4317
OTEL_EXPORTER_OTLP_HTTP_ENDPOINT=http://mycel_otel_collector:4318

TEMPORAL_HOST=mycel_temporal:7233
LOKI_URL=http://mycel_loki:3100
